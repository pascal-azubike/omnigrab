{
  "$schema": "https://schema.tauri.app/schema/v2/capabilities",
  "identifier": "default",
  "description": "Default capabilities for OmniGrab",
  "platforms": ["linux", "macOS", "windows", "android"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "yt-dlp",
          "sidecar": true,
          "args": true
        },
        {
          "name": "ffmpeg",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "store:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir",
    "os:default",
    "notification:default",
    "notification:allow-notify",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
