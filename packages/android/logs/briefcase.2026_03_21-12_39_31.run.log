author = "OmniGrab Contributors"
author_email = "hello@omnigrab.app"

[tool.briefcase.app.omnigrab-android]
formal_name = "OmniGrab"
description = "Download any video from any platform"
long_description = """OmniGrab lets you download videos, audio, and playlists from 1800+
platforms including YouTube, TikTok, Instagram, Twitter, Vimeo, Twitch and more."""
icon = "src/omnigrab_android/resources/omnigrab"
sources = ["src/omnigrab_android"]
test_sources = ["tests"]

requires = [
  "fastapi>=0.115.0",
  "uvicorn>=0.30.0",
  "yt-dlp>=2024.1.1",
  "aiofiles>=23.0.0",
  "python-multipart>=0.0.9",
]

[tool.briefcase.app.omnigrab-android.android]
requires = [
  "toga-android>=0.4.5",
]

[tool.briefcase.app.omnigrab-android.android.permissions]
