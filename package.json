{
  "name": "@omnigrab/monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:ui": "npm --prefix packages/ui run build",
    "build:ui:android": "npm --prefix packages/ui run build:android",
    "dev:desktop": "npm --prefix packages/desktop run dev",
    "build:desktop": "npm --prefix packages/desktop run build",
    "dev:android": "node scripts/dev-android.mjs",
    "dev:android:static": "npm run build:ui:android && cd packages/android && briefcase run android",
    "build:android": "cd packages/android && briefcase build android",
    "package:android": "cd packages/android && briefcase package android"
  }
}
